<%- include('partials/header') %>

<div class="hero">
  <h1>Find Your Next Dream Ride</h1>
  <p>Premium used cars and bikes at unbeatable prices.</p>
</div>

<div class="section">
  <h2 class="section-title">Available Vehicles</h2>
  <% if (items.length === 0) { %>
    <p class="empty-state">No vehicles listed yet. Be the first to <a href="/items/new">sell yours</a>!</p>
  <% } else { %>
    <div class="grid">
      <% items.forEach(item => { %>
        <div class="card">
          <div class="card-img" style="background-image: url('<%= item.imageURL %>');"></div>
          <div class="card-content">
            <span class="badge"><%= item.category %></span>
            <span class="badge badge-outline"><%= item.manufacturingYear %></span>
            <h3><%= item.title %></h3>
            <p class="price">$<%= item.price.toLocaleString() %></p>
            <a href="/items/<%= item._id %>" class="btn btn-secondary card-btn">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="section detail-section">
  <div class="detail-grid">
    <div class="detail-image" style="background-image: url('<%= item.imageURL %>');"></div>
    <div class="detail-content">
      <div class="badges">
        <span class="badge"><%= item.category %></span>
        <span class="badge badge-outline"><%= item.manufacturingYear %></span>
      </div>
      <h2><%= item.title %></h2>
      <p class="price-large">$<%= item.price.toLocaleString() %></p>
      
      <div class="description-box">
        <h3>Description</h3>
        <p><%= item.description %></p>
      </div>

      <div class="booking-card">
        <h3>Interested? Book a Visit</h3>
        <p>Schedule an appointment to see this vehicle in person.</p>
        
        <form action="/items/<%= item._id %>/appointments" method="POST" class="auth-form booking-form">
          <div class="form-group">
            <label for="customerName">Your Name</label>
            <input type="text" id="customerName" name="customerName" required placeholder="John Doe">
          </div>
          <div class="form-group">
            <label for="customerEmail">Your Email</label>
            <input type="email" id="customerEmail" name="customerEmail" required placeholder="john@example.com">
          </div>
          <div class="form-group">
            <label for="appointmentDate">Preferred Date</label>
            <input type="date" id="appointmentDate" name="appointmentDate" required>
          </div>
          <div class="form-group">
            <label for="message">Message (Optional)</label>
            <textarea id="message" name="message" rows="3" placeholder="Any specific questions?"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Confirm Appointment</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
